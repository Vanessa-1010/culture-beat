  "reviews": [
    { "apartment_id": 1, "author": "Jana", "rating": 5, "text": "Super transparente Vermieterin! Alle Infos waren akkurat. Wohnung ist toll, Nachbarschaft super freundlich.", "verified": true, "date": "2025-11-14" },
    { "apartment_id": 1, "author": "Tim", "rating": 5, "text": "Wirklich nachhaltig wie versprochen. ÖPNV ist perfekt. Gutes Preis-Leistungs-Verhältnis!", "verified": true, "date": "2025-10-03" },
    { "apartment_id": 1, "author": "User123", "rating": 4, "text": "Nebenkosten könnten unerwartet höher sein. Wichtig: Abrechnungen vorher ansehen!", "verified": false, "warning": true, "date": "2025-09-20" },
    { "apartment_id": 2, "author": "Klaus", "rating": 4, "text": "Modern und sauber, aber etwas laut wegen Straße.", "verified": true, "date": "2025-12-01" },
    { "apartment_id": 2, "author": "Monika", "rating": 3, "text": "Gut ausgestattet, aber der Vermieter reagiert manchmal langsam auf Anfragen.", "verified": true, "date": "2025-11-05" },
    { "apartment_id": 3, "author": "Community", "rating": 5, "text": "Genossenschaft ist klasse! Faire Miete, tolle Community, echte Nachhaltigkeit.", "verified": true, "date": "2025-12-10" },
    { "apartment_id": 3, "author": "Franziska", "rating": 5, "text": "Das beste Wohnerlebnis meines Lebens. Alle helfen einander, Events sind toll.", "verified": true, "date": "2025-10-28" },
    { "apartment_id": 4, "author": "Jonas", "rating": 4, "text": "Co-Living macht Spaß, tolle Leute kennengelernt. Coworking Space ist super.", "verified": true, "date": "2025-11-22" },
    { "apartment_id": 5, "author": "Studierende_1", "rating": 4, "text": "Günstigste Option in Berlin! Altbau-Charme, aber manchmal Heizprobleme im Winter.", "verified": true, "warning": true, "date": "2025-09-15" },
    { "apartment_id": 6, "author": "Hannah", "rating": 5, "text": "Traumhaft! Die Dachterrasse ist einfach unschlagbar und 100% Ökostrom inklusive.", "verified": true, "date": "2026-01-08" },
    { "apartment_id": 7, "author": "Max", "rating": 4, "text": "Wunderschöner Altbau, aber Energiekosten im Winter sind spürbar.", "verified": true, "warning": true, "date": "2025-12-20" },
    { "apartment_id": 8, "author": "Lena", "rating": 5, "text": "Tiny Living verändert den Blick auf das Wesentliche. Community-Garten ist ein Traum!", "verified": true, "date": "2026-02-14" },
    { "apartment_id": 9, "author": "Paul", "rating": 5, "text": "Leipzig ist günstig und belebt! Connewitz ist das beste Viertel Deutschlands.", "verified": true, "date": "2026-01-30" },
    { "apartment_id": 10, "author": "Business_Traveler", "rating": 4, "text": "Premium-Lage und Ausstattung, aber der Preis ist natürlich entsprechend.", "verified": true, "date": "2025-11-11" },
    { "apartment_id": 11, "author": "Nina", "rating": 5, "text": "Der Wald morgens – unbeschreiblich. Ökodorf-Atmosphäre ist einzigartig!", "verified": true, "date": "2026-03-05" },
    { "apartment_id": 12, "author": "Ersti2024", "rating": 4, "text": "Für Studienanfänger perfekt. Günstig, sicher, viele Kontakte. Zimmer ist klein, aber ausreichend.", "verified": true, "date": "2025-10-10" },
    { "apartment_id": 13, "author": "Kai", "rating": 5, "text": "Das Loft ist unglaublich! Hohe Decken, tolle Mitbewohner und super Lage in Eimsbüttel.", "verified": true, "date": "2026-02-20" },
    { "apartment_id": 13, "author": "Reni", "rating": 4, "text": "Schöne Wohnung, nachhaltige Gemeinschaft. Manchmal etwas laut vom Innenhof.", "verified": true, "date": "2026-01-15" },
    { "apartment_id": 14, "author": "Karin", "rating": 4, "text": "Toller Altbau, Pinakotheken zu Fuß erreichbar. Für München sehr faire Miete.", "verified": true, "date": "2025-12-05" },
    { "apartment_id": 15, "author": "Stefan", "rating": 4, "text": "Belgisches Viertel ist einfach wunderschön. Wohnung hat viel Charme, aber ältere Heizung.", "verified": true, "warning": true, "date": "2026-01-22" },
    { "apartment_id": 16, "author": "Mila", "rating": 5, "text": "Dresden Neustadt ist das Beste! Günstig, kreativ, nachhaltig. Genossenschaft top!", "verified": true, "date": "2026-02-10" },
    { "apartment_id": 17, "author": "Tobias", "rating": 5, "text": "Die Ökosiedlung hat mein Leben verändert. Zero Waste, Community, einfach perfekt.", "verified": true, "date": "2026-03-01" },
    { "apartment_id": 17, "author": "Kira", "rating": 5, "text": "Nachhaltigstes Wohnprojekt das ich kenne. Lastenrad inklusive ist ein Hammer!", "verified": true, "date": "2026-02-18" },
    { "apartment_id": 18, "author": "Felix", "rating": 4, "text": "Stylisches Apartment, Top-Lage. Belgisches Viertel macht süchtig. Etwas teuer aber lohnt sich.", "verified": true, "date": "2026-01-09" },
    { "apartment_id": 19, "author": "Anni", "rating": 5, "text": "Genossenschaft in Stuttgart Ost ist eine Perle! Weinberge, faire Miete, super Nachbarn.", "verified": true, "date": "2026-02-28" },
    { "apartment_id": 20, "author": "Leon", "rating": 5, "text": "Direkt am Tempelhofer Feld! Perfekt zum Radfahren, entspannter Kiez. Sehr empfehlenswert.", "verified": true, "date": "2026-03-10" },
    { "apartment_id": 21, "author": "Caro", "rating": 4, "text": "Für München günstig, Olympiapark direkt nebenan. Klein aber gemütlich.", "verified": true, "date": "2026-01-25" },
    { "apartment_id": 22, "author": "Jürgen", "rating": 5, "text": "HafenCity auf höchstem Niveau. Hafenblick morgens beim Kaffee – unbezahlbar.", "verified": true, "date": "2026-02-05" },
    { "apartment_id": 22, "author": "Kritiker99", "rating": 3, "text": "Lage und Ausstattung sind top, aber der Preis ist sehr hoch. Für Normalverdiener unrealistisch.", "verified": true, "warning": true, "date": "2026-01-18" },
    { "apartment_id": 23, "author": "Sonne", "rating": 5, "text": "Passivhaus mit Lastenrad und Gemeinschaftsgarten – das ist die Zukunft des Wohnens!", "verified": true, "date": "2026-03-12" },
    { "apartment_id": 24, "author": "Kreative_1", "rating": 5, "text": "Atelier-WG in Plagwitz ist ein Traum für Künstler! Günstiger geht's in Leipzig nicht.", "verified": true, "date": "2026-02-22" },
    { "apartment_id": 24, "author": "Marek", "rating": 4, "text": "Industriecharme und günstige Miete. Heizkörper könnten besser sein, aber sonst top.", "verified": true, "warning": true, "date": "2026-01-30" }
